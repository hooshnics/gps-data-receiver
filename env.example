# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
REQUEST_TIMEOUT=5s
MAX_REQUEST_SIZE=1048576  # 1MB in bytes

# Destination Servers (comma-separated URLs) — PiStat / primary destinations
DESTINATION_SERVERS=http://server1.example.com/api/gps,http://server2.example.com/api/gps,http://server3.example.com/api/gps

# Hooshnics async mirror (optional; independent of DESTINATION_SERVERS)
# HOOSHNICS_AUTH_TOKEN must match backend GPS_INGEST_TOKEN
# HOOSHNICS_MIRROR_ENABLED=false
# HOOSHNICS_AUTH_TOKEN=CHANGE_ME_INGEST_TOKEN
# HOOSHNICS_RAW_URL=https://data.hooshnics.com/api/gps/reports/raw
# HOOSHNICS_PARSED_URL=https://data.hooshnics.com/api/gps/reports
# HOOSHNICS_BUFFER_SIZE=50000
# HOOSHNICS_SPILL_DIR=logs/hooshnics_spill
# HOOSHNICS_WORKERS=4
# HOOSHNICS_TIMEOUT=15s

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_STREAM_NAME=gps:reports
REDIS_CONSUMER_GROUP=gps-workers
REDIS_MAX_LEN=10000  # Max stream length
# Reject new requests when queue depth >= this (0 = use 90% of REDIS_MAX_LEN). Reduces queue growth.
QUEUE_BACKPRESSURE_LIMIT=0

# Worker Configuration
WORKER_COUNT=50
WORKER_BATCH_SIZE=10

# Retry Configuration (shorter delays in production help avoid queue buildup when destinations are slow)
# Set MAX_RETRY_ATTEMPTS=0 for unlimited queue redelivery when data loss is unacceptable.
# The outgoing rate limiter (below) is the primary throttle for destination 429 responses.
MAX_RETRY_ATTEMPTS=5
RETRY_DELAY_FIRST=5s
RETRY_DELAY_SUBSEQUENT=10s

# HTTP Client Configuration
HTTP_CLIENT_TIMEOUT=30s
HTTP_CLIENT_MAX_IDLE_CONNS=100
HTTP_CLIENT_MAX_CONNS_PER_HOST=10

# Outgoing rate limit (per destination server)
# Set OUTGOING_RATE_LIMIT_RPS slightly below each Laravel app's per-IP rate limit.
# With round-robin across N destinations, each server receives ~total_RPS / N requests.
# Set to 0 to disable (not recommended when destinations enforce rate limits).
OUTGOING_RATE_LIMIT_RPS=50
OUTGOING_RATE_LIMIT_BURST=100

# Rate Limiting (incoming GPS device requests)
RATE_LIMIT_REQUESTS_PER_SECOND=1000
RATE_LIMIT_BURST=2000

# Logging
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json  # json or console

# PostgreSQL (stores raw and parsed data after successful delivery)
POSTGRES_ENABLED=true
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=gps
POSTGRES_PASSWORD=gps
POSTGRES_DB=gps_receiver
POSTGRES_SSLMODE=disable

# Environment
ENVIRONMENT=development  # development, production

# Teltonika binary protocol (native TCP device connections)
TELTONIKA_TCP_ENABLED=false
TELTONIKA_TCP_HOST=0.0.0.0
TELTONIKA_TCP_PORT=5055
TELTONIKA_TIMEZONE_OFFSET=3h30m
# Optional comma-separated IMEI whitelist (empty = allow all)
# TELTONIKA_IMEI_WHITELIST=3520930864036555,861826074262144

# Docker (optional — defaults use Arvan Cloud / npmmirror for Iran-restricted networks)
# DOCKER_REGISTRY=docker.arvancloud.ir
# NPM_REGISTRY=https://registry.npmmirror.com
# PostgreSQL image (defaults to Docker Hub; use mirror if Docker Hub is blocked)
# POSTGRES_IMAGE=docker.arvancloud.ir/postgres:16-alpine
# Override cAdvisor image if needed (default: mirror via DOCKER_REGISTRY/dockette/cadvisor:0.56.2)
# gcr.io/cadvisor is deprecated and often blocked; use GHCR or a mirror instead.
# CADVISOR_IMAGE=ghcr.io/google/cadvisor:0.56.2
# Apple Silicon / ARM64 dev (when mirror lacks arm64): CADVISOR_IMAGE=ghcr.io/google/cadvisor:0.56.2

# Grafana (required when using a public domain — fixes "origin not allowed" on login)
# Local dev: leave unset to use http://localhost:3000 defaults in docker-compose.yml
# Production (monitoring.hooshnics.com):
# GRAFANA_SERVER_ROOT_URL=https://monitoring.hooshnics.com
# GRAFANA_SERVER_DOMAIN=monitoring.hooshnics.com
# GRAFANA_SERVER_PROTOCOL=https
# Hostnames only, space-separated (not full URLs). GRAFANA_SERVER_DOMAIN is included automatically if omitted.
# GRAFANA_CSRF_TRUSTED_ORIGINS=monitoring.hooshnics.com localhost 127.0.0.1

