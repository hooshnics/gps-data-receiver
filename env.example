# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
REQUEST_TIMEOUT=5s
MAX_REQUEST_SIZE=1048576  # 1MB in bytes

# Destination Servers (comma-separated URLs)
DESTINATION_SERVERS=http://server1.example.com/api/gps,http://server2.example.com/api/gps,http://server3.example.com/api/gps

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_STREAM_NAME=gps:reports
REDIS_CONSUMER_GROUP=gps-workers
REDIS_MAX_LEN=10000  # Max stream length
# Reject new requests when queue depth >= this (0 = use 90% of REDIS_MAX_LEN). Reduces queue growth.
QUEUE_BACKPRESSURE_LIMIT=0

# Worker Configuration
WORKER_COUNT=50
WORKER_BATCH_SIZE=10

# Retry Configuration (shorter delays in production help avoid queue buildup when destinations are slow)
MAX_RETRY_ATTEMPTS=5
RETRY_DELAY_FIRST=5s
RETRY_DELAY_SUBSEQUENT=10s

# HTTP Client Configuration
HTTP_CLIENT_TIMEOUT=30s
HTTP_CLIENT_MAX_IDLE_CONNS=100
HTTP_CLIENT_MAX_CONNS_PER_HOST=10

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_SECOND=1000
RATE_LIMIT_BURST=2000

# Logging
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json  # json or console

# Raw device payload file logging (after successful delivery)
RAW_LOG_ENABLED=true
RAW_LOG_DIR=logs/raw
RAW_LOG_BUFFER_SIZE=10000

# PostgreSQL (stores raw and parsed data after successful delivery)
POSTGRES_ENABLED=true
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=gps
POSTGRES_PASSWORD=gps
POSTGRES_DB=gps_receiver
POSTGRES_SSLMODE=disable

# Environment
ENVIRONMENT=development  # development, production

# Docker (optional — defaults use Arvan Cloud / npmmirror for Iran-restricted networks)
# DOCKER_REGISTRY=docker.arvancloud.ir
# NPM_REGISTRY=https://registry.npmmirror.com
# PostgreSQL image (defaults to Docker Hub; use mirror if Docker Hub is blocked)
# POSTGRES_IMAGE=docker.arvancloud.ir/postgres:16-alpine
# Override cAdvisor image if needed (default: mirror via DOCKER_REGISTRY/dockette/cadvisor:0.56.2)
# gcr.io/cadvisor is deprecated and often blocked; use GHCR or a mirror instead.
# CADVISOR_IMAGE=ghcr.io/google/cadvisor:0.56.2
# Apple Silicon / ARM64 dev (when mirror lacks arm64): CADVISOR_IMAGE=ghcr.io/google/cadvisor:0.56.2

# Grafana (optional — defaults work for local access on port 3000)
# GRAFANA_SERVER_ROOT_URL=http://your-server-ip:3000
# GRAFANA_SERVER_DOMAIN=your-server-ip
# GRAFANA_SERVER_PROTOCOL=http
# GRAFANA_CSRF_TRUSTED_ORIGINS=http://your-server-ip:3000

